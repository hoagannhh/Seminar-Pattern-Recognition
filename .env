# ============================================================
#  .env.example  —  wikicities-population
#  Copy: cp .env.example .env  rồi điền giá trị thật
#  File .env đã có trong .gitignore → không bị commit
# ============================================================

# --- DBpedia SPARQL ------------------------------------------
SPARQL_ENDPOINT=https://dbpedia.org/sparql
SPARQL_PAGE_SIZE=1000
SPARQL_MAX_CITIES=10000
SPARQL_SLEEP_SEC=2.0

# --- Experiment config ---------------------------------------
RANDOM_SEED=42
TEST_SIZE=0.2
